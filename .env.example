# Neon Postgres — pooled connection (hostname contains "-pooler"); used by the app
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Neon Postgres — direct connection (no "-pooler"); used by Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# Separate Neon branch/database used ONLY by the automated test suite (tests truncate all tables)
TEST_DATABASE_URL="postgresql://USER:PASSWORD@ep-test-branch.region.aws.neon.tech/neondb?sslmode=require"
SESSION_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_BUSINESS_PHONE="+18005551234"
NEXT_PUBLIC_BUSINESS_PHONE_DISPLAY="(800) 555-1234"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
